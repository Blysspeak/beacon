{
  "productName": "Beacon",
  "version": "0.1.0",
  "identifier": "space.blysspeak.beacon",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Beacon — Deploy Dashboard",
        "width": 900,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$HOME/.beacon/**"]
      }
    }
  }
}
